class calculator
{
    void add(int a,int b)
    {
        System.out.println("Add: "+(a+b));
    }
    void add(int a,int b,int c)
    {
        System.out.println("Add: "+(a+b+c));
    }
    void add(double a,double b)
    {
        System.out.println("Add: "+(a+b));
    }
    public static void main(String[] args)
    {
        calculator c= new calculator();
        c.add(12,5);
        c.add(10,1,5);
        c.add(1.5,10.5);
    }
}
